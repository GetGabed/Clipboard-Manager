<Window x:Class="ClipboardManager.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings – Clipboard Manager"
        Width="420" Height="640" MinHeight="400"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True"
        Background="{DynamicResource SurfaceBrush}"
        WindowStartupLocation="CenterScreen">

    <!--
        Theme.xaml is intentionally NOT merged here; it lives in App.xaml so that
        the runtime DarkColors.xaml override takes effect.
    -->

    <Grid Margin="24" TextElement.Foreground="{DynamicResource TextPrimaryBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Settings" Style="{StaticResource HeadingText}"
                   FontSize="20" Margin="0,0,0,20"/>

        <!-- Settings form -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,0,4,0">
        <StackPanel>

            <!-- Max history items -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Max history items" Style="{StaticResource BodyText}"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Older items are removed automatically when the limit is reached."
                           Style="{StaticResource SubtitleText}" Margin="0,2,0,6"/>
                <Slider Minimum="10" Maximum="1000"
                        Value="{Binding MaxHistoryItems}"
                        TickFrequency="10" IsSnapToTickEnabled="True"
                        Width="300" HorizontalAlignment="Left"/>
                <TextBlock Text="{Binding MaxHistoryItems}"
                           Style="{StaticResource SubtitleText}"/>
            </StackPanel>

            <!-- Global Hotkey (capture on focus) -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Global hotkey" Style="{StaticResource BodyText}"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Click the box below then press a new key combination."
                           Style="{StaticResource SubtitleText}" Margin="0,2,0,6"/>
                <TextBox x:Name="HotkeyBox"
                         Text="{Binding HotkeyDisplay, Mode=OneWay}"
                         IsReadOnly="True"
                         Width="200" HorizontalAlignment="Left"
                         FontFamily="Segoe UI" FontSize="13"
                         Padding="8,5"
                         Background="{DynamicResource SurfaceAltBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         CaretBrush="{StaticResource PrimaryBrush}"
                         PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                         GotFocus="HotkeyBox_GotFocus"
                         LostFocus="HotkeyBox_LostFocus"
                         ToolTip="Click here then press your desired key combination"/>
            </StackPanel>

            <!-- Toggles -->
            <CheckBox Content="Start with Windows"
                      IsChecked="{Binding StartWithWindows}"
                      FontFamily="Segoe UI" FontSize="13" Cursor="Hand"
                      Margin="0,0,0,12"/>

            <CheckBox Content="Dark mode"
                      IsChecked="{Binding DarkMode}"
                      FontFamily="Segoe UI" FontSize="13" Cursor="Hand"
                      Margin="0,0,0,12"/>

            <CheckBox Content="Persist history to disk"
                      IsChecked="{Binding PersistToDisk}"
                      FontFamily="Segoe UI" FontSize="13" Cursor="Hand"
                      Margin="0,0,0,12"/>

            <!-- Export -->
            <StackPanel Margin="0,8,0,0">
                <TextBlock Text="Export history" Style="{StaticResource BodyText}"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Saves all text items to a .txt file and opens it in Notepad."
                           Style="{StaticResource SubtitleText}" Margin="0,2,0,8"/>
                <Button Content="📄 Export as TXT"
                        Command="{Binding ExportHistoryCommand}"
                        Style="{StaticResource IconButton}"
                        Padding="10,6" FontFamily="Segoe UI" FontSize="13"
                        HorizontalAlignment="Left"
                        Foreground="{StaticResource PrimaryBrush}"/>
            </StackPanel>

            <!-- Auto-expire -->
            <StackPanel Margin="0,16,0,16">
                <TextBlock Text="Auto-expire unpinned items" Style="{StaticResource BodyText}"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Automatically delete unpinned items older than N days. Set to 0 to keep forever."
                           Style="{StaticResource SubtitleText}" Margin="0,2,0,6" TextWrapping="Wrap"/>
                <Slider Minimum="0" Maximum="365"
                        Value="{Binding AutoExpireDays}"
                        TickFrequency="7" IsSnapToTickEnabled="True"
                        Width="300" HorizontalAlignment="Left"/>
                <TextBlock Text="{Binding AutoExpireDays, StringFormat='{}{0} days (0 = never)'}"
                           Style="{StaticResource SubtitleText}"/>
            </StackPanel>

            <!-- Excluded applications -->
            <StackPanel Margin="0,0,0,8">
                <TextBlock Text="Excluded applications" Style="{StaticResource BodyText}"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Clipboard won't be captured from these apps. Comma-separated process names, e.g. keepass, 1password, bitwarden"
                           Style="{StaticResource SubtitleText}" Margin="0,2,0,6" TextWrapping="Wrap"/>
                <TextBox Text="{Binding ExcludedApps, UpdateSourceTrigger=PropertyChanged}"
                         Width="340" HorizontalAlignment="Left"
                         FontFamily="Segoe UI" FontSize="12"
                         Padding="8,5" TextWrapping="Wrap"
                         Background="{DynamicResource SurfaceAltBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"/>
            </StackPanel>
        </StackPanel>
        </ScrollViewer>

        <!-- Action buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Reset Defaults"
                    Command="{Binding ResetCommand}"
                    Style="{StaticResource IconButton}"
                    Padding="12,8" FontFamily="Segoe UI" FontSize="13"
                    Margin="0,0,8,0"/>
            <Button Content="Save"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource PrimaryButton}"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
