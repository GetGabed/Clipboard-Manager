<Window x:Class="ClipboardManager.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ClipboardManager.ViewModels"
        xmlns:models="clr-namespace:ClipboardManager.Models"
        xmlns:helpers="clr-namespace:ClipboardManager.Helpers"
        Title="Clipboard Manager"
        Width="480" MinWidth="360"
        Height="600" MinHeight="300"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        Topmost="True"
        Focusable="True"
        Opacity="0">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <helpers:TimestampConverter      x:Key="TimestampConv"/>
            <helpers:ZeroToVisibleConverter  x:Key="ZeroToVis"/>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Drop shadow outer container -->
    <Border Margin="8" CornerRadius="12"
            Background="{StaticResource SurfaceBrush}">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="20"
                              Color="#40000000" Direction="0"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Header / drag bar -->
                <RowDefinition Height="Auto"/>  <!-- Search bar -->
                <RowDefinition Height="Auto"/>  <!-- Status bar -->
                <RowDefinition Height="*"/>     <!-- List (or empty state) -->
                <RowDefinition Height="Auto"/>  <!-- Action bar -->
            </Grid.RowDefinitions>

            <!-- ── Header ─────────────────────────────────────────── -->
            <Border Grid.Row="0" CornerRadius="12,12,0,0"
                    Background="{StaticResource PrimaryBrush}"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown"
                    Padding="16,12">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="📋" FontSize="18" Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Clipboard History" VerticalAlignment="Center"
                                   FontFamily="Segoe UI" FontSize="15" FontWeight="SemiBold"
                                   Foreground="White"/>
                    </StackPanel>

                    <!-- Item count badge (updates in real time via TotalCount) -->
                    <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                            Background="#33FFFFFF" CornerRadius="10" Padding="8,2">
                        <TextBlock Foreground="White" FontSize="11" FontFamily="Segoe UI"
                                   Text="{Binding TotalCount, StringFormat='{}{0} items'}"/>
                    </Border>

                    <!-- Right: Pinned-only toggle + Close -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <ToggleButton IsChecked="{Binding ShowPinnedOnly}"
                                      Style="{StaticResource IconToggleButton}"
                                      Padding="6,3" Margin="0,0,6,0"
                                      ToolTip="Show pinned items only">
                            <TextBlock Text="★" FontSize="14" Foreground="#FFFFC107"/>
                        </ToggleButton>
                        <Button Style="{StaticResource IconButton}"
                                Click="CloseButton_Click"
                                Background="Transparent" Width="28" Height="28"
                                ToolTip="Close (Esc)">
                            <TextBlock Text="✕" Foreground="White" FontSize="13"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Search bar ─────────────────────────────────────── -->
            <Grid Grid.Row="1" Margin="12,10,12,4">
                <!-- Search icon -->
                <TextBlock Text="🔍" FontSize="14" Margin="10,0,0,0"
                           VerticalAlignment="Center" HorizontalAlignment="Left"
                           Panel.ZIndex="1"/>
                <TextBox Style="{StaticResource SearchBox}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         x:Name="SearchTextBox"/>
                <!-- Clear (✕) button — visible when search box has text -->
                <Button Style="{StaticResource IconButton}"
                        HorizontalAlignment="Right" Margin="0,0,6,0"
                        Command="{Binding ClearSearchCommand}"
                        Visibility="{Binding HasSearchText, Converter={StaticResource BoolToVis}}"
                        Width="24" Height="24" Panel.ZIndex="1"
                        ToolTip="Clear search (Ctrl+A, Del)">
                    <TextBlock Text="✕" FontSize="10"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </Button>
            </Grid>

            <!-- ── Status bar ─────────────────────────────────────── -->
            <TextBlock Grid.Row="2" Margin="14,2,14,4"
                       Style="{StaticResource SubtitleText}"
                       Text="{Binding FilteredItems.Count,
                              StringFormat='Showing {0} result(s) — Press Enter or ⧉ to copy'}"/>

            <!-- ── Items list ──────────────────────────────────────── -->
            <Grid Grid.Row="3">
                <ListBox Style="{StaticResource HistoryListBox}"
                         ItemContainerStyle="{StaticResource HistoryListItem}"
                         ItemsSource="{Binding FilteredItems}"
                         SelectedItem="{Binding SelectedItem}"
                         x:Name="ItemsListBox"
                         MouseDoubleClick="ItemsListBox_MouseDoubleClick"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         KeyDown="ItemsListBox_KeyDown">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ClipboardItem}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>  <!-- pin star -->
                                    <ColumnDefinition Width="Auto"/>  <!-- image thumbnail -->
                                    <ColumnDefinition Width="*"/>     <!-- preview text -->
                                    <ColumnDefinition Width="Auto"/>  <!-- hover copy btn -->
                                    <ColumnDefinition Width="56"/>    <!-- timestamp -->
                                </Grid.ColumnDefinitions>

                                <!-- Pin star (only for pinned items) -->
                                <TextBlock Grid.Column="0" Text="★" FontSize="13"
                                           Margin="0,0,6,0" VerticalAlignment="Center"
                                           Foreground="{StaticResource PinnedBrush}"
                                           ToolTip="Pinned"
                                           Visibility="{Binding IsPinned,
                                                        Converter={StaticResource BoolToVis}}"/>

                                <!-- Image thumbnail (50×50, only for image entries) -->
                                <Border Grid.Column="1" Width="50" Height="50"
                                        Margin="0,0,8,0" CornerRadius="4"
                                        ClipToBounds="True">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ContentType}"
                                                             Value="{x:Static models:ClipboardContentType.Image}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <!-- Full-size preview on hover -->
                                    <Border.ToolTip>
                                        <ToolTip MaxWidth="520" MaxHeight="420" Padding="4">
                                            <Image Source="{Binding ImageThumbnail}"
                                                   MaxWidth="500" MaxHeight="400"
                                                   Stretch="Uniform"/>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <Image Source="{Binding ImageThumbnail}"
                                           Stretch="UniformToFill"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                </Border>

                                <!-- File-type icon (22×22, only for file items) -->
                                <Image Grid.Column="1"
                                       Source="{Binding FileIcon}"
                                       Width="22" Height="22"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="HighQuality">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ContentType}"
                                                             Value="{x:Static models:ClipboardContentType.Files}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>

                                <!-- Preview text + subtitle (image dims / file info) -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                            ToolTip="{Binding FilePathsTooltip}">
                                    <TextBlock Style="{StaticResource BodyText}"
                                               Text="{Binding Preview}"/>

                                    <!-- Image dimensions: e.g. 1920 × 1080 -->
                                    <TextBlock Margin="0,2,0,0"
                                               Text="{Binding ImageDimensions}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource SubtitleText}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ContentType}"
                                                                 Value="{x:Static models:ClipboardContentType.Image}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- Files / Other sub-label -->
                                    <TextBlock Margin="0,2,0,0"
                                               Text="{Binding ContentType}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource SubtitleText}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ContentType}"
                                                                 Value="{x:Static models:ClipboardContentType.Files}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ContentType}"
                                                                 Value="{x:Static models:ClipboardContentType.Other}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Per-item hover copy button (⧉) -->
                                <Button Grid.Column="3"
                                        Command="{Binding DataContext.CopyItemCommand,
                                                  RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"
                                        Padding="6,4" Margin="4,0"
                                        VerticalAlignment="Center"
                                        ToolTip="Copy to clipboard">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                            <Setter Property="Visibility" Value="Hidden"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMouseOver,
                                                             RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                                             Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="⧉" FontSize="14"
                                               Foreground="{StaticResource PrimaryBrush}"/>
                                </Button>

                                <!-- Timestamp: HH:mm today, MMM d otherwise -->
                                <TextBlock Grid.Column="4"
                                           Style="{StaticResource SubtitleText}"
                                           Text="{Binding CapturedAt, Converter={StaticResource TimestampConv}}"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Empty-state overlay -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            IsHitTestVisible="False"
                            Visibility="{Binding FilteredItems.Count, Converter={StaticResource ZeroToVis}}">
                    <TextBlock Text="📋" FontSize="40" HorizontalAlignment="Center"
                               Opacity="0.25"/>
                    <TextBlock Text="Nothing copied yet"
                               FontFamily="Segoe UI" FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    <TextBlock Text="Copy something and it will appear here."
                               FontFamily="Segoe UI" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,0" Opacity="0.7"/>
                </StackPanel>
            </Grid>

            <!-- ── Action toolbar ─────────────────────────────────── -->
            <Border Grid.Row="4" BorderThickness="0,1,0,0"
                    BorderBrush="{StaticResource BorderBrush}"
                    Background="{StaticResource SurfaceAltBrush}"
                    CornerRadius="0,0,12,12"
                    Padding="12,8">
                <Grid>
                    <!-- Transform flyout popup -->
                    <Popup x:Name="TransformPopup"
                           Placement="Top"
                           PlacementTarget="{Binding ElementName=TransformButton}"
                           StaysOpen="False"
                           AllowsTransparency="True">
                        <Border Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="4">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="12" Color="#30000000"/>
                            </Border.Effect>
                            <StackPanel MinWidth="180">
                                <TextBlock Text="Transform Text"
                                           FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                           Margin="8,6,8,4"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <Button Content="UPPERCASE"               Command="{Binding TransformCommand}" CommandParameter="Uppercase"      Style="{StaticResource IconButton}" HorizontalContentAlignment="Left" Padding="8,5" Click="TransformPopupItem_Click"/>
                                <Button Content="lowercase"               Command="{Binding TransformCommand}" CommandParameter="Lowercase"      Style="{StaticResource IconButton}" HorizontalContentAlignment="Left" Padding="8,5" Click="TransformPopupItem_Click"/>
                                <Button Content="Title Case"              Command="{Binding TransformCommand}" CommandParameter="TitleCase"      Style="{StaticResource IconButton}" HorizontalContentAlignment="Left" Padding="8,5" Click="TransformPopupItem_Click"/>
                                <Button Content="Sentence case"           Command="{Binding TransformCommand}" CommandParameter="SentenceCase"   Style="{StaticResource IconButton}" HorizontalContentAlignment="Left" Padding="8,5" Click="TransformPopupItem_Click"/>
                                <Separator Margin="4,2"/>
                                <Button Content="Trim Whitespace"         Command="{Binding TransformCommand}" CommandParameter="TrimWhitespace"  Style="{StaticResource IconButton}" HorizontalContentAlignment="Left" Padding="8,5" Click="TransformPopupItem_Click"/>
                                <Button Content="Remove Extra Spaces"     Command="{Binding TransformCommand}" CommandParameter="RemoveSpaces"   Style="{StaticResource IconButton}" HorizontalContentAlignment="Left" Padding="8,5" Click="TransformPopupItem_Click"/>
                                <Separator Margin="4,2"/>
                                <Button Content="Base64 Encode"           Command="{Binding TransformCommand}" CommandParameter="Base64Encode"   Style="{StaticResource IconButton}" HorizontalContentAlignment="Left" Padding="8,5" Click="TransformPopupItem_Click"/>
                                <Button Content="Base64 Decode"           Command="{Binding TransformCommand}" CommandParameter="Base64Decode"   Style="{StaticResource IconButton}" HorizontalContentAlignment="Left" Padding="8,5" Click="TransformPopupItem_Click"/>
                                <Button Content="URL Encode"              Command="{Binding TransformCommand}" CommandParameter="UrlEncode"      Style="{StaticResource IconButton}" HorizontalContentAlignment="Left" Padding="8,5" Click="TransformPopupItem_Click"/>
                                <Button Content="URL Decode"              Command="{Binding TransformCommand}" CommandParameter="UrlDecode"      Style="{StaticResource IconButton}" HorizontalContentAlignment="Left" Padding="8,5" Click="TransformPopupItem_Click"/>
                                <Button Content="HTML Encode"             Command="{Binding TransformCommand}" CommandParameter="HtmlEncode"     Style="{StaticResource IconButton}" HorizontalContentAlignment="Left" Padding="8,5" Click="TransformPopupItem_Click"/>
                                <Button Content="HTML Decode"             Command="{Binding TransformCommand}" CommandParameter="HtmlDecode"     Style="{StaticResource IconButton}" HorizontalContentAlignment="Left" Padding="8,5" Click="TransformPopupItem_Click"/>
                                <Separator Margin="4,2"/>
                                <Button Content="Reverse Text"            Command="{Binding TransformCommand}" CommandParameter="Reverse"        Style="{StaticResource IconButton}" HorizontalContentAlignment="Left" Padding="8,5" Click="TransformPopupItem_Click"/>
                                <Button Content="Count Chars / Words / Lines" Command="{Binding TransformCommand}" CommandParameter="Count"     Style="{StaticResource IconButton}" HorizontalContentAlignment="Left" Padding="8,5" Click="TransformPopupItem_Click"/>
                            </StackPanel>
                        </Border>
                    </Popup>

                    <!-- Secondary actions (left) -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="📌 Pin"
                                Style="{StaticResource IconButton}"
                                Command="{Binding PinSelectedCommand}"
                                Padding="8,4" FontFamily="Segoe UI" FontSize="12"
                                Margin="0,0,4,0"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                ToolTip="Pin / Unpin (P)"/>
                        <Button Content="🗑 Delete"
                                Style="{StaticResource IconButton}"
                                Command="{Binding DeleteSelectedCommand}"
                                Padding="8,4" FontFamily="Segoe UI" FontSize="12"
                                Margin="0,0,4,0"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                ToolTip="Delete (Del)"/>
                        <Button Content="🧹 Clear All"
                                Style="{StaticResource IconButton}"
                                Command="{Binding ClearHistoryCommand}"
                                Padding="8,4" FontFamily="Segoe UI" FontSize="12"
                                Margin="0,0,4,0"
                                Foreground="{StaticResource DangerBrush}"
                                ToolTip="Clear all unpinned history"/>
                        <!-- Transform: text items only -->
                        <Button x:Name="TransformButton"
                                Content="🔡 Transform"
                                Style="{StaticResource IconButton}"
                                Padding="8,4" FontFamily="Segoe UI" FontSize="12"
                                Margin="0,0,4,0"
                                Foreground="{StaticResource PrimaryBrush}"
                                ToolTip="Transform text"
                                Click="TransformButton_Click"
                                Visibility="{Binding SelectedItemIsText, Converter={StaticResource BoolToVis}}"/>
                        <!-- Open Folder: file items only -->
                        <Button Content="📂 Open Folder"
                                Style="{StaticResource IconButton}"
                                Command="{Binding OpenFolderCommand}"
                                Padding="8,4" FontFamily="Segoe UI" FontSize="12"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                ToolTip="Open containing folder (Explorer)"
                                Visibility="{Binding SelectedItemIsFiles, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <!-- Primary Copy action (right) + "Copied!" toast -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <!-- "Copied!" confirmation toast (fades out after 600 ms via code-behind) -->
                        <Border x:Name="CopiedToast"
                                Background="{StaticResource SuccessBrush}"
                                CornerRadius="6" Padding="10,4"
                                Margin="0,0,8,0" Opacity="0"
                                VerticalAlignment="Center">
                            <TextBlock Text="✅ Copied!" Foreground="White"
                                       FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"/>
                        </Border>

                        <Button Content="📋 Copy"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding CopySelectedCommand}"
                                HorizontalAlignment="Right"
                                Padding="16,6"
                                ToolTip="Copy selected item to clipboard (Enter) · Esc to close"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
