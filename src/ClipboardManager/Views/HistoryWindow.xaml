<Window x:Class="ClipboardManager.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ClipboardManager.ViewModels"
        xmlns:models="clr-namespace:ClipboardManager.Models"
        Title="Clipboard Manager"
        Width="480" MinWidth="360"
        Height="600" MinHeight="300"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        Topmost="True"
        Focusable="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Drop shadow outer container -->
    <Border Margin="8" CornerRadius="12"
            Background="{StaticResource SurfaceBrush}">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="20"
                              Color="#40000000" Direction="0"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Header / drag bar -->
                <RowDefinition Height="Auto"/>  <!-- Search bar -->
                <RowDefinition Height="Auto"/>  <!-- Status bar -->
                <RowDefinition Height="*"/>     <!-- List -->
                <RowDefinition Height="Auto"/>  <!-- Action bar -->
            </Grid.RowDefinitions>

            <!-- ── Header ─────────────────────────────────────────── -->
            <Border Grid.Row="0" CornerRadius="12,12,0,0"
                    Background="{StaticResource PrimaryBrush}"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown"
                    Padding="16,12">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="📋" FontSize="18" Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Clipboard History" VerticalAlignment="Center"
                                   FontFamily="Segoe UI" FontSize="15" FontWeight="SemiBold"
                                   Foreground="White"/>
                    </StackPanel>

                    <!-- Item count badge -->
                    <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                            Background="#33FFFFFF" CornerRadius="10" Padding="8,2">
                        <TextBlock Foreground="White" FontSize="11" FontFamily="Segoe UI"
                                   Text="{Binding TotalCount, StringFormat='{}{0} items'}"/>
                    </Border>

                    <!-- Close button -->
                    <Button Style="{StaticResource IconButton}"
                            HorizontalAlignment="Right"
                            Click="CloseButton_Click"
                            Background="Transparent" Width="28" Height="28"
                            ToolTip="Close (Esc)">
                        <TextBlock Text="✕" Foreground="White" FontSize="13"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>

            <!-- ── Search bar ─────────────────────────────────────── -->
            <Grid Grid.Row="1" Margin="12,10,12,4">
                <!-- Search icon -->
                <TextBlock Text="🔍" FontSize="14" Margin="10,0,0,0"
                           VerticalAlignment="Center" HorizontalAlignment="Left"
                           Panel.ZIndex="1"/>
                <TextBox Style="{StaticResource SearchBox}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         x:Name="SearchTextBox"/>
                <!-- Clear button -->
                <Button Style="{StaticResource IconButton}"
                        HorizontalAlignment="Right" Margin="0,0,6,0"
                        Command="{Binding ClearSearchCommand}"
                        Visibility="{Binding SearchText.Length,
                                     Converter={StaticResource BoolToVis}}"
                        Width="24" Height="24" Panel.ZIndex="1">
                    <TextBlock Text="✕" FontSize="10"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </Button>
            </Grid>

            <!-- ── Status bar ─────────────────────────────────────── -->
            <TextBlock Grid.Row="2" Margin="14,2,14,4"
                       Style="{StaticResource SubtitleText}"
                       Text="{Binding FilteredItems.Count,
                              StringFormat='Showing {0} result(s) — double-click or Enter to paste'}"/>

            <!-- ── Items list ──────────────────────────────────────── -->
            <ListBox Grid.Row="3"
                     Style="{StaticResource HistoryListBox}"
                     ItemContainerStyle="{StaticResource HistoryListItem}"
                     ItemsSource="{Binding FilteredItems}"
                     SelectedItem="{Binding SelectedItem}"
                     x:Name="ItemsListBox"
                     MouseDoubleClick="ItemsListBox_MouseDoubleClick"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:ClipboardItem}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>  <!-- pin icon -->
                                <ColumnDefinition Width="*"/>     <!-- preview text -->
                                <ColumnDefinition Width="Auto"/>  <!-- time + type badge -->
                            </Grid.ColumnDefinitions>

                            <!-- Pin star -->
                            <TextBlock Grid.Column="0" Text="★" FontSize="14" Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource PinnedBrush}"
                                       Visibility="{Binding IsPinned,
                                                    Converter={StaticResource BoolToVis}}"/>

                            <!-- Preview text -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource BodyText}"
                                           Text="{Binding Preview}"/>
                                <TextBlock Style="{StaticResource SubtitleText}"
                                           Margin="0,2,0,0"
                                           Text="{Binding ContentType}"/>
                            </StackPanel>

                            <!-- Time -->
                            <TextBlock Grid.Column="2"
                                       Style="{StaticResource SubtitleText}"
                                       Text="{Binding CapturedAt, StringFormat='{}{0:HH:mm}'}"
                                       Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- ── Action toolbar ─────────────────────────────────── -->
            <Border Grid.Row="4" BorderThickness="0,1,0,0"
                    BorderBrush="{StaticResource BorderBrush}"
                    Background="{StaticResource SurfaceAltBrush}"
                    CornerRadius="0,0,12,12"
                    Padding="12,8">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="📌 Pin"
                                Style="{StaticResource IconButton}"
                                Command="{Binding PinSelectedCommand}"
                                Padding="8,4" FontFamily="Segoe UI" FontSize="12"
                                Margin="0,0,4,0"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                ToolTip="Pin / Unpin (P)"/>
                        <Button Content="🗑 Delete"
                                Style="{StaticResource IconButton}"
                                Command="{Binding DeleteSelectedCommand}"
                                Padding="8,4" FontFamily="Segoe UI" FontSize="12"
                                Margin="0,0,4,0"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                ToolTip="Delete (Del)"/>
                        <Button Content="🧹 Clear All"
                                Style="{StaticResource IconButton}"
                                Command="{Binding ClearHistoryCommand}"
                                Padding="8,4" FontFamily="Segoe UI" FontSize="12"
                                Foreground="{StaticResource DangerBrush}"
                                ToolTip="Clear all history"/>
                    </StackPanel>

                    <Button Content="⏎  Paste"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding PasteSelectedCommand}"
                            HorizontalAlignment="Right"
                            Padding="16,6"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
